<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QL Sinh Viên</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="SinhVien" asp-action="Index">
                    🎓 QLSV
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">

                    <!-- LEFT -->
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="SinhVien" asp-action="Index">Sinh viên</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="HocPhan" asp-action="Index">Học phần</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="HocPhan" asp-action="Index">Đăng ký</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="HocPhan" asp-action="GioHang">
                                🛒 Giỏ hàng
                                @{
                                    var count = 0;
                                    if (Context.Session.GetString("MaSV") != null)
                                    {
                                        var db = Context.RequestServices
                                        .GetService(typeof(NguyenTanSang_1899.Models.ApplicationDbContext))
                                        as NguyenTanSang_1899.Models.ApplicationDbContext;

                                        count = db.ChiTietDangKys
                                        .Count(x => x.DangKy.MaSV == Context.Session.GetString("MaSV"));
                                    }
                                }
                                <span class="cart-badge">@count</span>
                            </a>
                        </li>

                    </ul>

                    <!-- RIGHT -->
                    <ul class="navbar-nav">

                        @if (Context.Session.GetString("MaSV") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link user-info">
                                    👤 @Context.Session.GetString("MaSV")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link logout-btn" asp-controller="NguoiDung" asp-action="DangXuat">
                                    Đăng xuất
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link login-btn" asp-controller="NguoiDung" asp-action="DangNhap">
                                    Đăng nhập
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- CONTENT -->
    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="footer text-center mt-5">
        <div class="container">
            © 2026 - QL Sinh Viên
        </div>
    </footer>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>